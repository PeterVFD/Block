<!DOCTYPE html>
<html lang="de">
<head>
   <script>
    window.PROTECTED_HUB_URL = "https://petervfd.github.io/haupt/";
  </script>
  <script src="schutz.js"></script>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blockteilzeit-Rechner</title>

<style>
    :root {
        --rot: #e60000;
        --rot-dunkel: #b80000;
        --grau-bg: #f3f4f6;
        --karte: #ffffff;
        --text: #222;
        --linie: #ddd;
        --soft: #fafafa;
    }

    body {
        margin: 0;
        font-family: Segoe UI, Arial, sans-serif;
        background: var(--grau-bg);
        color: var(--text);
        padding: 20px;
    }

    .app {
        max-width: 850px;
        margin: auto;
        background: var(--karte);
        border-radius: 18px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.12);
        overflow: hidden;
    }

    .kopf {
        background: linear-gradient(135deg, var(--rot), var(--rot-dunkel));
        color: white;
        padding: 22px;
        text-align: center;
    }

    .kopf h1 {
        margin: 0;
        font-size: 26px;
    }

    .kopf p {
        margin: 8px 0 0;
        font-size: 14px;
        opacity: 0.95;
    }

    .inhalt {
        padding: 22px;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .feld {
        display: flex;
        flex-direction: column;
    }

    label {
        font-weight: 600;
        margin-bottom: 6px;
        font-size: 14px;
    }

    input, select {
        padding: 11px;
        border: 1px solid var(--linie);
        border-radius: 10px;
        font-size: 15px;
        box-sizing: border-box;
        width: 100%;
    }

    input:focus, select:focus {
        outline: none;
        border-color: var(--rot);
        box-shadow: 0 0 0 2px rgba(230,0,0,0.12);
    }

    button {
        width: 100%;
        margin-top: 20px;
        padding: 14px;
        border: none;
        border-radius: 12px;
        background: var(--rot);
        color: white;
        font-size: 17px;
        font-weight: 700;
        cursor: pointer;
    }

    button:hover {
        background: var(--rot-dunkel);
    }

    .ergebnis {
        margin-top: 22px;
        display: none;
    }

    .karten {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .karte {
        background: var(--soft);
        border: 1px solid #e5e5e5;
        border-radius: 14px;
        padding: 16px;
    }

    .karte .titel {
        font-size: 13px;
        color: #666;
        margin-bottom: 6px;
    }

    .karte .wert {
        font-size: 24px;
        font-weight: 800;
        color: var(--rot);
    }

    .details {
        margin-top: 16px;
        padding: 14px;
        background: #f7f7f7;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.7;
    }

    .hinweis {
        margin-top: 18px;
        background: #fff7f7;
        border-left: 5px solid var(--rot);
        padding: 14px;
        border-radius: 10px;
        font-size: 14px;
        line-height: 1.5;
    }

    .fehler {
        margin-top: 16px;
        background: #fff0f0;
        color: #9b0000;
        padding: 12px;
        border-radius: 10px;
        display: none;
        font-weight: 600;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 14px;
        background: white;
        border-radius: 12px;
        overflow: hidden;
    }

    th, td {
        padding: 10px;
        border-bottom: 1px solid #e5e5e5;
        text-align: left;
        font-size: 14px;
    }

    th {
        background: #eeeeee;
    }

    .badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .arbeit {
        background: #e8f5e9;
        color: #1b5e20;
    }

    .frei {
        background: #e3f2fd;
        color: #0d47a1;
    }

    @media(max-width: 700px) {
        .grid,
        .karten {
            grid-template-columns: 1fr;
        }

        body {
            padding: 10px;
        }

        .kopf h1 {
            font-size: 22px;
        }

        th, td {
            font-size: 13px;
        }
    }
</style>
</head>

<body>

<div class="app">

    <div class="kopf">
        <h1>Blockteilzeit-Rechner</h1>
        <p>Berechnung des geglätteten Brutto- und Nettogehalts inklusive Monatsübersicht</p>
    </div>

    <div class="inhalt">

        <div class="grid">

            <div class="feld">
                <label for="brutto">Aktuelles Vollzeit-Bruttogehalt monatlich (€)</label>
                <input type="number" id="brutto" placeholder="z. B. 3500" step="0.01">
            </div>

            <div class="feld">
                <label for="steuerklasse">Steuerklasse</label>
                <select id="steuerklasse">
                    <option value="1">Steuerklasse I</option>
                    <option value="2">Steuerklasse II</option>
                    <option value="3">Steuerklasse III</option>
                    <option value="4">Steuerklasse IV</option>
                    <option value="5">Steuerklasse V</option>
                    <option value="6">Steuerklasse VI</option>
                </select>
            </div>

            <div class="feld">
                <label for="arbeit">Monate Arbeitsphase</label>
                <input type="number" id="arbeit" placeholder="z. B. 1" step="1">
            </div>

            <div class="feld">
                <label for="frei">Monate Freistellungsphase</label>
                <input type="number" id="frei" placeholder="z. B. 1" step="1">
            </div>

            <div class="feld">
                <label for="startmonat">Erster Monat mit geringerem Gehalt</label>
                <select id="startmonat">
                    <option value="0">Januar</option>
                    <option value="1">Februar</option>
                    <option value="2">März</option>
                    <option value="3">April</option>
                    <option value="4">Mai</option>
                    <option value="5">Juni</option>
                    <option value="6">Juli</option>
                    <option value="7">August</option>
                    <option value="8">September</option>
                    <option value="9">Oktober</option>
                    <option value="10">November</option>
                    <option value="11">Dezember</option>
                </select>
            </div>

            <div class="feld">
                <label for="sonderzahlung">Sonderzahlungen jährlich optional (€)</label>
                <input type="number" id="sonderzahlung" placeholder="z. B. 1000" step="0.01">
            </div>

            <div class="feld">
                <label for="nettofaktor">Netto-Schätzung</label>
                <select id="nettofaktor">
                    <option value="auto">Automatisch nach Steuerklasse</option>
                    <option value="0.80">80 % vom Brutto</option>
                    <option value="0.75">75 % vom Brutto</option>
                    <option value="0.70">70 % vom Brutto</option>
                    <option value="0.65">65 % vom Brutto</option>
                    <option value="0.60">60 % vom Brutto</option>
                    <option value="0.55">55 % vom Brutto</option>
                    <option value="0.50">50 % vom Brutto</option>
                </select>
            </div>

        </div>

        <button onclick="berechnen()">Berechnen</button>

        <div id="fehler" class="fehler"></div>

        <div id="ergebnis" class="ergebnis">

            <div class="karten">

                <div class="karte">
                    <div class="titel">Neues Brutto monatlich</div>
                    <div class="wert" id="btBrutto">0,00 €</div>
                </div>

                <div class="karte">
                    <div class="titel">Neues Netto monatlich</div>
                    <div class="wert" id="btNetto">0,00 €</div>
                </div>

                <div class="karte">
                    <div class="titel">Neues Brutto für 2 Monate</div>
                    <div class="wert" id="brutto2Monate">0,00 €</div>
                </div>

                <div class="karte">
                    <div class="titel">Neues Netto für 2 Monate</div>
                    <div class="wert" id="netto2Monate">0,00 €</div>
                </div>

                <div class="karte">
                    <div class="titel">Monatliche Brutto-Differenz</div>
                    <div class="wert" id="differenz">0,00 €</div>
                </div>

                <div class="karte">
                    <div class="titel">Blockteilzeit-Quote</div>
                    <div class="wert" id="quote">0 %</div>
                </div>

            </div>

            <div class="details" id="details"></div>

            <div class="details">
                <b>Monate mit geringerem Gehalt</b>
                <div id="monatsliste"></div>
            </div>

            <div class="hinweis">
                <b>Hinweis:</b><br>
                Die Netto-Berechnung ist nur eine grobe Schätzung. Sie ersetzt keine verbindliche Entgeltabrechnung.
                Steuerklasse, Krankenversicherung, Zusatzbeitrag, Kinderfreibeträge, Kirchensteuer, Bundesland und weitere Faktoren
                werden hier nicht exakt berechnet.
            </div>

        </div>

    </div>

</div>

<script>
function euro(wert) {
    return wert.toLocaleString("de-DE", {
        style: "currency",
        currency: "EUR"
    });
}

function prozent(wert) {
    return wert.toLocaleString("de-DE", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    }) + " %";
}

function getNettoFaktor(steuerklasse) {
    switch (steuerklasse) {
        case "1": return 0.66;
        case "2": return 0.68;
        case "3": return 0.75;
        case "4": return 0.66;
        case "5": return 0.55;
        case "6": return 0.50;
        default: return 0.66;
    }
}

function berechnen() {
    const brutto = parseFloat(document.getElementById("brutto").value) || 0;
    const arbeit = parseInt(document.getElementById("arbeit").value) || 0;
    const frei = parseInt(document.getElementById("frei").value) || 0;
    const steuerklasse = document.getElementById("steuerklasse").value;
    const nettoAuswahl = document.getElementById("nettofaktor").value;
    const sonderzahlung = parseFloat(document.getElementById("sonderzahlung").value) || 0;
    const startmonat = parseInt(document.getElementById("startmonat").value);

    const fehler = document.getElementById("fehler");
    const ergebnis = document.getElementById("ergebnis");

    fehler.style.display = "none";
    ergebnis.style.display = "none";

    if (brutto <= 0) {
        fehler.innerText = "Bitte tragen Sie Ihr aktuelles monatliches Vollzeit-Bruttogehalt ein.";
        fehler.style.display = "block";
        return;
    }

    if (arbeit <= 0) {
        fehler.innerText = "Bitte tragen Sie mindestens 1 Monat Arbeitsphase ein.";
        fehler.style.display = "block";
        return;
    }

    if (frei < 0) {
        fehler.innerText = "Die Freistellungsphase darf nicht negativ sein.";
        fehler.style.display = "block";
        return;
    }

    const gesamtMonate = arbeit + frei;

    if (gesamtMonate <= 0) {
        fehler.innerText = "Bitte tragen Sie eine gültige Laufzeit ein.";
        fehler.style.display = "block";
        return;
    }

    const quote = arbeit / gesamtMonate;

    const sonderzahlungMonatlichAlt = sonderzahlung / 12;
    const sonderzahlungMonatlichNeu = sonderzahlungMonatlichAlt * quote;

    const btBruttoOhneSonder = brutto * quote;
    const btBrutto = btBruttoOhneSonder + sonderzahlungMonatlichNeu;

    let nettoFaktor;

    if (nettoAuswahl === "auto") {
        nettoFaktor = getNettoFaktor(steuerklasse);
    } else {
        nettoFaktor = parseFloat(nettoAuswahl);
    }

    const btNetto = btBrutto * nettoFaktor;

    const brutto2Monate = btBrutto * 2;
    const netto2Monate = btNetto * 2;

    const bruttoAltMitSonder = brutto + sonderzahlungMonatlichAlt;
    const differenz = bruttoAltMitSonder - btBrutto;

    const gesamtAlt = bruttoAltMitSonder * gesamtMonate;
    const gesamtNeuBrutto = btBrutto * gesamtMonate;
    const gesamtNeuNetto = btNetto * gesamtMonate;
    const gesamtDifferenz = gesamtAlt - gesamtNeuBrutto;

    document.getElementById("btBrutto").innerText = euro(btBrutto);
    document.getElementById("btNetto").innerText = euro(btNetto);
    document.getElementById("brutto2Monate").innerText = euro(brutto2Monate);
    document.getElementById("netto2Monate").innerText = euro(netto2Monate);
    document.getElementById("differenz").innerText = euro(differenz);
    document.getElementById("quote").innerText = prozent(quote * 100);

    document.getElementById("details").innerHTML = `
        <b>Berechnung:</b><br>
        Aktuelles Vollzeit-Brutto monatlich: ${euro(brutto)}<br>
        Arbeitsphase: ${arbeit} Monat(e)<br>
        Freistellungsphase: ${frei} Monat(e)<br>
        Gesamtlaufzeit mit reduziertem Gehalt: ${gesamtMonate} Monat(e)<br><br>

        <b>Formel:</b><br>
        ${euro(brutto)} × ${arbeit} ÷ ${gesamtMonate} = ${euro(btBruttoOhneSonder)}<br><br>

        <b>Gesamtwerte über die Blockteilzeit:</b><br>
        Neues Brutto gesamt: ${euro(gesamtNeuBrutto)}<br>
        Geschätztes Netto gesamt: ${euro(gesamtNeuNetto)}<br>
        Brutto-Differenz gesamt gegenüber Vollzeit: ${euro(gesamtDifferenz)}<br><br>

        <b>Sonderzahlung:</b><br>
        Jährliche Sonderzahlung: ${euro(sonderzahlung)}<br>
        Monatlich vorher: ${euro(sonderzahlungMonatlichAlt)}<br>
        Monatlich während Blockteilzeit: ${euro(sonderzahlungMonatlichNeu)}
    `;

    erstelleMonatsliste(startmonat, gesamtMonate, arbeit, frei, btBrutto, btNetto);

    ergebnis.style.display = "block";
}

function erstelleMonatsliste(startmonat, gesamtMonate, arbeit, frei, btBrutto, btNetto) {
    const monate = [
        "Januar", "Februar", "März", "April", "Mai", "Juni",
        "Juli", "August", "September", "Oktober", "November", "Dezember"
    ];

    let html = `
        <table>
            <thead>
                <tr>
                    <th>Nr.</th>
                    <th>Monat</th>
                    <th>Phase</th>
                    <th>Brutto</th>
                    <th>Netto geschätzt</th>
                </tr>
            </thead>
            <tbody>
    `;

    for (let i = 0; i < gesamtMonate; i++) {
        const monatIndex = (startmonat + i) % 12;
        const jahrPlus = Math.floor((startmonat + i) / 12);
        const monatName = monate[monatIndex] + (jahrPlus > 0 ? " +" + jahrPlus : "");

        let phase = "";
        let klasse = "";

        if (i < arbeit) {
            phase = "Arbeitsphase";
            klasse = "arbeit";
        } else {
            phase = "Freistellung";
            klasse = "frei";
        }

        html += `
            <tr>
                <td>${i + 1}</td>
                <td>${monatName}</td>
                <td><span class="badge ${klasse}">${phase}</span></td>
                <td>${euro(btBrutto)}</td>
                <td>${euro(btNetto)}</td>
            </tr>
        `;
    }

    html += `
            </tbody>
        </table>
    `;

    document.getElementById("monatsliste").innerHTML = html;
}
</script>

</body>
</html>
